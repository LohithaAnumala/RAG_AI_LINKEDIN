from fastapi import FastAPI from pydantic import BaseModel from fastapi.middleware.cors import CORSMiddleware from fastapi.responses import FileResponse import wikipedia import time import logging from sentence_transformers import SentenceTransformer, CrossEncoder from rank_bm25 import BM25Okapi from transformers import pipeline # ------------------ INIT ------------------ app = FastAPI() app.add_middleware( CORSMiddleware, allow_origins=["*"], allow_methods=["*"], allow_headers=["*"], ) logging.basicConfig(level=logging.INFO) # ------------------ INPUT ------------------ class Query(BaseModel): question: str # ------------------ MODELS ------------------ embedder = SentenceTransformer("all-MiniLM-L6-v2") reranker = CrossEncoder("cross-encoder/ms-marco-MiniLM-L-6-v2") llm = pipeline("text-generation", model="distilgpt2") # lightweight local # ------------------ WIKI ------------------ def fetch_wikipedia(query): try: results = wikipedia.search(query) for title in results[:3]: try: page = wikipedia.page(title) return page.content except: continue return None except: return None # ------------------ SEMANTIC CHUNKING ------------------ def semantic_chunk(text, chunk_size=500): sentences = text.split(". ") chunks = [] current_chunk = "" for sent in sentences: if len(current_chunk) + len(sent) < chunk_size: current_chunk += sent + ". " else: chunks.append(current_chunk) current_chunk = sent + ". " if current_chunk: chunks.append(current_chunk) return chunks # ------------------ HYBRID RETRIEVAL ------------------ def hybrid_retrieval(chunks, query): # BM25 tokenized = [c.split() for c in chunks] bm25 = BM25Okapi(tokenized) bm25_scores = bm25.get_scores(query.split()) # Embeddings chunk_embeds = embedder.encode(chunks) query_embed = embedder.encode([query])[0] # cosine similarity import numpy as np scores = [] for i, chunk in enumerate(chunks): sim = np.dot(chunk_embeds[i], query_embed) / ( np.linalg.norm(chunk_embeds[i]) * np.linalg.norm(query_embed) ) final_score = 0.5 * bm25_scores[i] + 0.5 * sim scores.append((chunk, final_score)) scores = sorted(scores, key=lambda x: x[1], reverse=True) top_chunks = [s[0] for s in scores[:5]] return top_chunks # ------------------ RERANK ------------------ def rerank(query, chunks): pairs = [(query, c) for c in chunks] scores = reranker.predict(pairs) ranked = sorted(zip(chunks, scores), key=lambda x: x[1], reverse=True) return [r[0] for r in ranked[:3]] # ------------------ CONTEXT ------------------ def build_context(chunks): return "\n".join(chunks) # ------------------ LLM ------------------ def generate_answer(context, question): prompt = f""" Answer based only on context. Context: {context} Question: {question} Answer: """ result = llm(prompt, max_length=200, do_sample=False) return result[0]["generated_text"] # ------------------ GROUND TRUTH ------------------ def extract_ground_truth(context, question): return context[:300] # simple baseline # ------------------ EVAL ------------------ def faithfulness(context, answer): return "High" if answer.lower()[:50] in context.lower() else "Low" def relevance(question, answer): words = question.lower().split() match = sum([1 for w in words if w in answer.lower()]) return "High" if match >= 2 else "Low" # ------------------ PIPELINE ------------------ def rag_pipeline(query): text = fetch_wikipedia(query) if not text: return { "answer": "No data found", "faithfulness": "Low", "relevance": "Low", "ground_truth": "NA" } chunks = semantic_chunk(text) retrieved = hybrid_retrieval(chunks, query) reranked = rerank(query, retrieved) context = build_context(reranked) answer = generate_answer(context, query) ground_truth = extract_ground_truth(context, query) f = faithfulness(context, answer) r = relevance(query, answer) return { "answer": answer, "faithfulness": f, "relevance": r, "ground_truth": ground_truth } # ------------------ API ------------------ @app.post("/ask") def ask(q: Query): start = time.time() result = rag_pipeline(q.question) latency = round(time.time() - start, 2) result["latency"] = f"{latency}s" return result # ------------------ FRONTEND ------------------ @app.get("/") def home(): return FileResponse("index.html")
